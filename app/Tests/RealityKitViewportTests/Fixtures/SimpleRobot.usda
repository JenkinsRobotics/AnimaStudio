#usda 1.0
(
    defaultPrim = "SimpleRobot"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "SimpleRobot"
{
    def Cube "Body"
    {
        double size = 1
        color3f[] primvars:displayColor = [(0.2, 0.35, 0.8)]
        double3 xformOp:scale = (0.8, 1.1, 0.5)
        double3 xformOp:translate = (0, 0.55, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    def Xform "HeadYaw"
    {
        double3 xformOp:translate = (0, 1.3, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Cube "Head"
        {
            double size = 1
            color3f[] primvars:displayColor = [(0.95, 0.45, 0.12)]
            double3 xformOp:scale = (0.72, 0.46, 0.58)
            double3 xformOp:translate = (0, 0.23, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
    }
}
